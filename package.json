{
  "name": "campusos-x-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix apps/gateway && npm install --prefix apps/auth-service && npm install --prefix apps/dashboard-web",
    "dev:gateway": "npm start --prefix apps/gateway",
    "dev:auth": "npm start --prefix apps/auth-service",
    "dev:dashboard": "npm run dev --prefix apps/dashboard-web",
    "dev:attendance": "cd apps/attendance-service && ../../venv/bin/uvicorn main:app --port 4002 --reload",
    "dev:assignments": "cd apps/assignment-service && ../../venv/bin/uvicorn main:app --port 4003 --reload",
    "dev:timetable": "cd apps/timetable-service && ../../venv/bin/uvicorn main:app --port 4005 --reload",
    "dev:gpt": "cd apps/campus-gpt && ../../venv/bin/uvicorn main:app --port 4007 --reload",
    "dev:ai": "cd apps/ai-orchestrator && ../../venv/bin/uvicorn brain:app --port 4009 --reload",
    "dev:dashboard-service": "cd apps/dashboard-service && ../../venv/bin/uvicorn main:app --port 4011 --reload",
    "dev": "concurrently \"npm run dev:gateway\" \"npm run dev:auth\" \"npm run dev:dashboard\" \"npm run dev:attendance\" \"npm run dev:assignments\" \"npm run dev:timetable\" \"npm run dev:gpt\" \"npm run dev:ai\" \"npm run dev:dashboard-service\"",
    "infra": "cd infra/docker && docker-compose up -d"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
